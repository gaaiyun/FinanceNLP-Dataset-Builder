# FinanceNLP Dataset Builder - 环境变量配置示例
# 复制此文件为 .env 并填入你的 API Keys

# ===== 新闻数据源 =====

# Finnhub API (财经新闻)
# 获取：https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# NewsAPI (全球新闻)
# 获取：https://newsapi.org/register
NEWSAPI_API_KEY=your_newsapi_key_here

# ===== 社交媒体 =====

# Twitter API v2
# 获取：https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Reddit API
# 获取：https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_SECRET=your_reddit_secret_here

# ===== 文本处理（可选）=====

# OpenAI API (用于高级情感分析)
# 获取：https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ===== 其他配置（可选）=====

# 代理配置（如果需要）
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# 日志级别
# LOG_LEVEL=INFO
